# Renomeie para .env e preencha os valores

# OpenAI
OPENAI_API_KEY=sk-...

# Telegram
TELEGRAM_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=-100123456789

# WhatsApp (Selenium)
WHATSAPP_GRUPO=Nome Exato do Grupo
WHATSAPP_CANAL=Nome Exato do Canal
WHATSAPP_PERFIL=./perfil_chrome

# Links que aparecem no rodapé da mensagem
# Deixe em branco ou remova a linha para não exibir aquele link
LINK_WHATSAPP=https://chat.whatsapp.com/...
LINK_WHATSAPP_CANAL=https://whatsapp.com/channel/...
LINK_TELEGRAM=https://t.me/...
